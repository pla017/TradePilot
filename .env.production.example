# Docker host port. Use 80 for direct http://服务器IP access, or 3000 if port 80 is occupied.
HOST_PORT=80

# App internal port. Usually do not change this.
PORT=3000
NODE_ENV=production
TZ=Asia/Shanghai

# Runtime SQLite location inside container. Usually do not change this.
TRADEPILOT_DATA_DIR=/app/runtime-data

# Replace this with your real DeepSeek API key before deployment.
DEEPSEEK_API_KEY=sk-e10bdfb9287c41028607efa0082c9282
